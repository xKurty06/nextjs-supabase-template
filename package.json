{
  "name": "nextjs-supabase-template",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack-ready Next.js template with TypeScript, TailwindCSS, Supabase, and lucide-react icons.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
