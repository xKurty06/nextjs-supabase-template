# Public app metadata.
NEXT_PUBLIC_APP_NAME="Next.js Supabase Template"

# Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Safe to expose to the browser when Row Level Security is configured properly.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key. Never expose this to the frontend or commit real values.
SUPABASE_SERVICE_ROLE_KEY=

# Put real secrets in .env.local. Do not commit .env.local to GitHub.
